Host *
    AddKeysToAgent yes
    ChallengeResponseAuthentication no
    HashKnownHosts yes
    IdentityFile ~/.ssh/id_ed25519
    # On first-time connections, you may need to temporarily set this to "yes" to
    # add the host key to the known_hosts file.
    PasswordAuthentication no
    UseKeychain yes
    VisualHostKey yes
    HostkeyAlgorithms ssh-ed25519
    PubkeyAcceptedAlgorithms ssh-ed25519

Host jsatk-tower
    HostName jsatk-tower.local
    User root
    Port 222

# vim: set syntax=sshconfig:
